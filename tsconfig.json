{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",

		"module": "nodenext",
		"target": "esnext",

		"types": ["node", "vitest/globals"],

		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		"strict": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"skipLibCheck": true
	},

	"include": ["src", "**/*.test.ts"],

	"exclude": ["node_modules", "dist"]
}
